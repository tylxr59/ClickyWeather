{
  "name": "clickyweather",
  "author": "tylxr",
  "description": "Card-based weather app for button-first Pebble watches.",
  "version": "1.4.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "scripts": {
    "build": "pebble build",
    "clean": "pebble clean",
    "install:emery": "pebble install --emulator emery --vnc",
    "release:notes": "node tools/extract-release-notes.js",
    "test": "node tests/pkjs-utils.test.js && node tests/pkjs-integration.test.js"
  },
  "dependencies": {
    "@rebble/clay": "^1.0.8"
  },
